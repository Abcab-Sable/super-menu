# super-menu — copy this file to `.env` and fill in your values.
# `.env` is gitignored, so your key never gets committed. Loaded from the
# directory you run `super-menu` in. A real shell export takes precedence.

# Self-hosted Valhalla — real road routing with NO API key and no per-use cost.
# Highest priority: if set, it is used over ORS. See the plugin's deploy/ folder
# (docker-compose.yml) to stand one up in a few commands.
# VALHALLA_URL=http://localhost:8002

# OpenRouteService API key — enables real road-following routes in the
# route-avoider (web UI, TUI, CLI). Free key: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Optional: point at a self-hosted OpenRouteService instance instead of the
# hosted API. Leave unset to use the default hosted endpoint.
# ORS_BASE_URL=https://api.openrouteservice.org
